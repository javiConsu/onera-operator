# =============================================================================
# Pulsa — Configuración de Entorno
# =============================================================================
# Copia este archivo a .env y rellena los valores.
# Basado en onera-operator. Optimizado para el mercado hispanohablante.

# -----------------------------------------------------------------------------
# Base de Datos (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://pulsa:pulsa@localhost:5432/pulsa

# -----------------------------------------------------------------------------
# Redis (para la cola de tareas BullMQ)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Configuración del Proveedor de IA
# -----------------------------------------------------------------------------
# Proveedor: openai | azure | anthropic | openai-compatible
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-5
AI_API_KEY=sk-ant-tu-api-key-aqui

# Modelo premium para agentes críticos (chat, captación, investigación, ingeniería)
AI_PREMIUM_MODEL=claude-opus-4-6
AI_PREMIUM_PROVIDER=anthropic
AI_PREMIUM_API_KEY=

# -----------------------------------------------------------------------------
# Email (Azure Email Communication Service)
# -----------------------------------------------------------------------------
AZURE_EMAIL_CONNECTION_STRING=
AZURE_EMAIL_SENDER=hola@pulsa.pro

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Búsqueda Web (Serper — https://serper.dev)
# -----------------------------------------------------------------------------
SERPER_API_KEY=

# -----------------------------------------------------------------------------
# Crawling Web (Crawl4AI)
# -----------------------------------------------------------------------------
CRAWL4AI_API_URL=http://localhost:11235

# -----------------------------------------------------------------------------
# Ejecución de Código (E2B — https://e2b.dev)
# -----------------------------------------------------------------------------
E2B_API_KEY=

# -----------------------------------------------------------------------------
# Twitter/X
# -----------------------------------------------------------------------------
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# Autenticación (Clerk — https://clerk.com)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/new

# -----------------------------------------------------------------------------
# Facturación (DodoPayments — https://dodopayments.com)
# -----------------------------------------------------------------------------
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=whsec_...
DODO_PAYMENTS_ENVIRONMENT=live_mode
# IMPORTANTE: actualizar con el dominio definitivo cuando Javi lo confirme
DODO_PAYMENTS_RETURN_URL=https://app.pulsa.pro/dashboard?billing=success
DODO_SUBSCRIPTION_PRODUCT_ID=
DODO_GROWTH_PRODUCT_ID=
DODO_SCALE_PRODUCT_ID=
DODO_POWER_PRODUCT_ID=
DODO_MEGA_PRODUCT_ID=

# -----------------------------------------------------------------------------
# Programación del Ciclo de Agentes
# -----------------------------------------------------------------------------
AGENT_LOOP_INTERVAL_CRON=0 */4 * * *
DAILY_REPORT_CRON=0 18 * * *

# -----------------------------------------------------------------------------
# Configuración del Servidor
# IMPORTANTE: actualizar con el dominio definitivo cuando Javi lo confirme
# -----------------------------------------------------------------------------
BACKEND_PORT=3001
# Dominios pendientes de confirmar por Javi (ver LAN-98):
FRONTEND_URL=https://app.pulsa.pro
NEXT_PUBLIC_BACKEND_URL=https://api.pulsa.pro
