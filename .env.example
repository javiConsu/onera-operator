# =============================================================================
# Onera Operator - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://onera:onera@localhost:5432/onera

# -----------------------------------------------------------------------------
# Redis (for BullMQ task queue)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
# Supported providers: openai | azure | anthropic | openai-compatible
AI_PROVIDER=openai
AI_MODEL=gpt-4o
AI_API_KEY=sk-your-api-key-here

# Only needed for openai-compatible or local models
AI_BASE_URL=

# Only needed for Azure OpenAI (use AI_BASE_URL instead if you have the full endpoint)
AI_AZURE_RESOURCE_NAME=
AI_AZURE_DEPLOYMENT_NAME=

# -----------------------------------------------------------------------------
# Web Search (Exa API — https://exa.ai)
# -----------------------------------------------------------------------------
# Get your API key at: https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# -----------------------------------------------------------------------------
# Authentication (Clerk — https://clerk.com)
# -----------------------------------------------------------------------------
# Create an app at: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/new

# -----------------------------------------------------------------------------
# Agent Loop Scheduling
# -----------------------------------------------------------------------------
# Cron expression for the autonomous agent loop (default: every 4 hours)
AGENT_LOOP_INTERVAL_CRON=0 */4 * * *

# Cron expression for daily report generation (default: 6 PM daily)
DAILY_REPORT_CRON=0 18 * * *

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
